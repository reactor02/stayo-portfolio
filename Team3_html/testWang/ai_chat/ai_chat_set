 <!-- ai 세트 -->
    <link rel="stylesheet" href="../css/T3_2nd_ai_chat.css">
    <script src="../js/T3_2nd_ai_chat.js"></script>
    <div id="ai-trigger" class="ai-trigger">
      <span>AI<br>상담사</span>
    </div>

    <!-- ② 채팅창 -->
    <div id="ai-chat-container" class="ai-chat-container" style="display: none;">
      <div class="ai-chat-header">
        <span class="title">STAYO AI 상담원</span>
        <button id="ai-close-btn" class="ai-close-btn">×</button>
      </div>

      <div id="ai-chat-box" class="ai-chat-box">
        <div class="message model">
          <div class="bubble">안녕하세요! STAYO 숙박 예약 상담원입니다. 무엇을 도와드릴까요?</div>
        </div>
      </div>

      <div class="ai-chat-input-area">
        <textarea id="ai-prompt" placeholder="메시지 입력..." rows="1"></textarea>
        <button id="ai-ask-btn">전송</button>
      </div>
    </div>